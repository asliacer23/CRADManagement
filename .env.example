# PostgreSQL direct connection URL (used by Vite dev-server API plugins)
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# Same URL exposed under the SUPABASE_DB_URL alias (fallback)
SUPABASE_DB_URL=postgresql://postgres.<project-ref>:<password>@aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres

# Supabase project settings (used by the frontend Supabase client)
VITE_SUPABASE_PROJECT_ID=<your-supabase-project-id>
VITE_SUPABASE_URL=https://<your-supabase-project-id>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=<your-supabase-publishable-key>
